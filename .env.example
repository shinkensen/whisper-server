# ── Whisper Transcription Server Config ──────────────────────────────
# Copy to .env and edit as needed

# Model size: tiny | base | small | medium | large-v2 | large-v3
# 'base' is a good balance for 1GB RAM — ~150MB VRAM/RAM, decent accuracy
# 'tiny' uses ~80MB, less accurate but fastest
WHISPER_MODEL=base

# Device: cpu (safe default) or cuda (if you have a GPU)
WHISPER_DEVICE=cpu

# Compute type: int8 (best for CPU) | float16 (GPU) | int8_float16 (GPU)
WHISPER_COMPUTE=int8

# Beam size: lower = faster + less RAM, slightly less accurate
WHISPER_BEAM=1

# Max upload file size in MB
MAX_FILE_MB=50

# Server port
PORT=8000