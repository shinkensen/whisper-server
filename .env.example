# ── Whisper Transcription Server Config (Node.js) ─────────────────────
# Copy to .env and edit as needed

# Model size: tiny | base | small | medium | large-v2 | large-v3
# 'base' is a good balance for 1GB RAM — ~150MB RAM, decent accuracy
# 'tiny' uses ~80MB, less accurate but fastest
WHISPER_MODEL=small

# Language: auto (detect) or a code like en, es, fr, de, etc.
# Specifying a language is faster and more accurate
WHISPER_LANGUAGE=auto

# Max upload file size in MB
MAX_FILE_MB=50

# Server port
PORT=8000